# Copy this file to .env and fill in real values.
# .env is gitignored and must never be committed.

# Retell — required to deploy agents and fetch calls.
RETELL_API_KEY=

# Optional: set to the public base URL of the webhook service to wire each
# agent's webhook_url to <WEBHOOK_BASE_URL>/webhook/retell during deploy.
WEBHOOK_BASE_URL=

# Post-call webhook service.
# RETELL_WEBHOOK_KEY is the Retell API key that carries the "webhook" badge; it
# signs the X-Retell-Signature header. The service refuses to start without it.
RETELL_WEBHOOK_KEY=

# SMTP settings for EmailAlert (only needed when a client sets alert_email).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Twilio SMS sender (booking-link texts). When all three are set, the post-call
# service sends via Twilio; otherwise it uses DebugSms (logs only).
# NOTE: toll-free FROM numbers require Twilio Toll-Free Verification before
# carriers will deliver SMS — until verified, sends are carrier-blocked.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
